<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.DawaiBuddy" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary colors -->
        <item name="colorPrimary">@color/green_dark_light</item>
        <item name="colorOnPrimary">@color/white_dark_green</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/green_light_dark</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background_2</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/green_dark_light</item>

        <!-- Navigation bar (bottom system bar) -->
        <item name="android:navigationBarColor">@color/background_2</item>

    </style>

    <style name="CustomActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/green_light_vdark</item>
    </style>

</resources>