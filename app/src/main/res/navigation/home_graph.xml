<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_graph"
    app:startDestination="@id/mainPageFragment">

    <fragment
        android:id="@+id/mainPageFragment"
        android:name="com.ebookfrenzy.dawaibuddy.MainPageFragment"
        android:label="fragment_main_page"
        tools:layout="@layout/fragment_main_page" >
        <action
            android:id="@+id/action_mainPageFragment_to_profileFragment2"
            app:destination="@id/profileFragment"
            app:enterAnim="@anim/in"
            app:exitAnim="@anim/out"
            app:popEnterAnim="@anim/in"
            app:popExitAnim="@anim/out"/>
    </fragment>
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.ebookfrenzy.dawaibuddy.ProfileFragment"
        android:label="fragment_profile"
        tools:layout="@layout/fragment_profile" >
        <action
            android:id="@+id/action_profileFragment_to_mainPageFragment2"
            app:destination="@id/mainPageFragment"
            app:enterAnim="@anim/in"
            app:exitAnim="@anim/out"
            app:popEnterAnim="@anim/in"
            app:popExitAnim="@anim/out"/>
    </fragment>
</navigation>